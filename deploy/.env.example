# =============================================================================
# Chatbot Platform — environment variable reference
#
# Copy this file to .env and fill in real values. This file is documentation
# only — it contains NO real secrets or defaults. Missing required variables
# cause the application to refuse to start (fail-fast, CLAUDE.md §3).
# =============================================================================

# -- Deployment mode ----------------------------------------------------------
# "saas"          — multi-tenant SaaS (default for shared infrastructure)
# "single_tenant" — dedicated install for one client
DEPLOYMENT_MODE=saas

# -- Data stores --------------------------------------------------------------
# Primary PostgreSQL (direct DSN for migrations; PgBouncer DSN for the app).
DATABASE_URL=postgres://<user>:<password>@<host>:5432/<dbname>

# Redis (used for: rate limiting, JWT blacklist, Celery broker/result backend).
REDIS_URL=redis://<host>:6379

# -- Secrets (required — never commit real values) ----------------------------
JWT_SECRET=<at-least-32-random-characters>
SECRET_ENCRYPTION_KEY=<base64-encoded-32-byte-key>

# -- Observability ------------------------------------------------------------
LOG_LEVEL=INFO
SERVICE_NAME=api

# -- Auth / cookie ------------------------------------------------------------
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_NAME=access_token
ACCESS_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_TTL_SECONDS=1800

# Set to true in development only — logs the reset token so you can paste it
# into the reset endpoint without an email provider. MUST be false in production.
AUTH_RESET_TOKEN_LOG=false

# -- Widget / visitor session -------------------------------------------------
VISITOR_SESSION_TTL_SECONDS=1800
WIDGET_SESSION_RATE_LIMIT_MAX=30
WIDGET_SESSION_RATE_LIMIT_WINDOW_SECONDS=60

# -- Rate limiting (auth endpoints) -------------------------------------------
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# -- CORS ---------------------------------------------------------------------
CORS_PREFLIGHT_MAX_AGE=600
CORS_ORIGIN_CACHE_TTL_SECONDS=300

# -- LLM provider (per-tenant config overrides these) -------------------------
LLM_MAX_TOKENS=1024
LLM_DEFAULT_MODEL=claude-opus-4-8
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=30.0

# -- Document ingestion / object storage (S5.2) -------------------------------
# Storage backend. Currently only "local" is supported; S3/GCS slots in later.
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=local. The directory where raw uploads and
# parsed artifacts are written (tenant-prefixed subdirectories are created
# automatically). Missing → application refuses to start (fail-fast).
STORAGE_LOCAL_ROOT=<absolute-path-to-storage-root>

# Maximum accepted upload size in bytes (default 10 MiB = 10485760).
INGESTION_MAX_UPLOAD_BYTES=10485760

# -- Celery broker + result backend (S5.1) ------------------------------------
# Both default to REDIS_URL when unset. Override here to point at a different
# Redis logical database (e.g. /1 for broker, /2 for results) or a separate
# Redis instance. If neither CELERY_BROKER_URL nor REDIS_URL is set, the
# application refuses to start (fail-fast).
#
# CELERY_BROKER_URL=redis://<host>:6379/1
# CELERY_RESULT_BACKEND=redis://<host>:6379/2
#
# Worker launch (Windows: --pool=solo required; prefork cannot fork on Windows):
#   venv\python.exe -m celery -A api.tasks.celery_app worker --loglevel=info --pool=solo
#
# Beat launch (empty schedule until S8.3):
#   venv\python.exe -m celery -A api.tasks.celery_app beat --loglevel=info

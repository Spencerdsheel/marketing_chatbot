# .env.example — Chatbot Platform Configuration
# THIS FILE IS DOCUMENTATION, NOT DEFAULTS.
# Copy to .env and fill real values. Never commit real secrets.

# ============================================================================
# Docker Compose / Infrastructure Configuration
# ============================================================================

# PostgreSQL container environment variables
POSTGRES_USER=chatbot              # Username for postgres
POSTGRES_PASSWORD=chatbot          # Password for postgres (PLACEHOLDER — use strong value in .env)
POSTGRES_DB=chatbot                # Name of the main application database

# Port mappings (host:container)
POSTGRES_PORT=5432                 # Postgres direct connection port
PGBOUNCER_PORT=6432                # PgBouncer pooler connection port
REDIS_PORT=6379                    # Redis port

# ============================================================================
# Application Configuration (services/common)
# ============================================================================

# Hybrid delivery mode — drives SaaS vs dedicated single-tenant behavior
DEPLOYMENT_MODE=saas              # one of: saas | single_tenant

# PostgreSQL connection — for the application via PgBouncer (transaction pool mode).
# Note: asyncpg through PgBouncer transaction mode requires statement_cache_size=0.
# This is handled in S0.2 app wiring; documented here for reference.
DATABASE_URL=postgresql://chatbot:chatbot@localhost:6432/chatbot

# Direct PostgreSQL DSN for migrations and integration tests.
# (PgBouncer transaction mode cannot run DDL; migrations must connect directly.)
DATABASE_URL_DIRECT=postgresql://chatbot:chatbot@localhost:5432/chatbot

# Test database DSN (optional). If unset, integration tests are skipped (unit tests always run).
# Used by services/common integration tests and must have pgvector extension.
TEST_DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot_test

# Redis cache and rate-limit broker (optional). If unset/unreachable, falls back to in-memory.
REDIS_URL=redis://localhost:6379/0

# Repository implementation selector.
REPOSITORY=postgres               # one of: postgres | memory

# Authentication and encryption secrets — REQUIRED.
# Use long random values; never reuse across environments. Never commit real values.
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars-for-jwt-signing

# 32-byte key for AES-256-GCM secret encryption at rest (provider keys, OAuth tokens, etc).
# Accepts base64url-encoded (no padding) OR 64 hex characters.
SECRET_ENCRYPTION_KEY=change-me-32-bytes-base64url-or-hex-for-aes256-gcm

# Observability
LOG_LEVEL=INFO                     # one of: DEBUG | INFO | WARNING | ERROR | CRITICAL
SERVICE_NAME=common                # Identifies this service in logs and traces

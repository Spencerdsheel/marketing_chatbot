# services/common — example configuration. THIS FILE IS DOCUMENTATION, NOT DEFAULTS.
# Copy to .env and fill real values. Required values have NO default; the app fails
# fast at startup if they are missing. Never commit real secrets.

# Hybrid delivery mode — drives SaaS vs dedicated single-tenant behavior.
DEPLOYMENT_MODE=saas            # one of: saas | single_tenant

# PostgreSQL (asyncpg DSN). pgvector extension must be available in this database.
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot

# Redis (optional). If unset/unreachable, cache + rate limiting fall back to in-memory.
REDIS_URL=redis://localhost:6379/0

# Repository implementation selector.
REPOSITORY=postgres            # one of: postgres | memory

# Auth secrets — REQUIRED. Use long random values; never reuse across environments.
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars

# 32-byte key for AES-256-GCM secret encryption, base64url-encoded (no padding) OR 64 hex chars.
SECRET_ENCRYPTION_KEY=change-me-32-bytes-base64url-or-hex

# Observability
LOG_LEVEL=INFO
SERVICE_NAME=common

# Integration tests only (optional). A Postgres where `CREATE EXTENSION vector` works.
# If unset, integration tests are skipped (unit tests always run).
# TEST_DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_test

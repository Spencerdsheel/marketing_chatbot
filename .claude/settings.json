{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Projects/chatbot/marketing_chatbot/.claude/hooks/block_commands.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Projects/chatbot/marketing_chatbot/.claude/hooks/protect_paths.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"C:/Projects/chatbot/marketing_chatbot/.claude/hooks/verify_reminder.py\""
          }
        ]
      }
    ]
  }
}

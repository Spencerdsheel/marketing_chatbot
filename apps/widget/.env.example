# Build-time default gateway base URL, baked into the widget.js bundle via
# Vite `define` (see vite.config.ts). This is a PUBLIC URL, not a secret —
# the widget is served from the platform's own CDN, so the gateway address
# is known at build time. Integrators can still override it per-embed with
# the script tag's `data-api-base` attribute; this is only the fallback.
#
# Production example: VITE_WIDGET_API_BASE=https://api.example-platform.com
VITE_WIDGET_API_BASE=http://localhost:8000
